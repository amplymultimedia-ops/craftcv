# Backend example environment for local/dev/prod
PORT=3000

# Use either local SQLite DATABASE_URL or Supabase SUPABASE_DATABASE_URL
DATABASE_URL=file:./dev.db
SUPABASE_DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Public backend URL used by Better Auth callbacks
BACKEND_URL=http://localhost:3000

# Auth and provider keys
BETTER_AUTH_SECRET=replace-with-long-random-secret
OPENAI_API_KEY=
RESEND_API_KEY=
